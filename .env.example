# Local: copy to .env
PORT=8080
MONGODB_URI=mongodb://127.0.0.1:27017/placetowebsite

# ── Google Sign-In ────────────────────────────────────────────────────────────
# Create an OAuth "Web application" client at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: http://localhost:5173 (and your Vercel URL in production)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── JWT ───────────────────────────────────────────────────────────────────────
# Sign JWTs for API auth — use a long random string in production:
#   openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-secret

# ── Root admin dashboard (/admin on frontend) ────────────────────────────────
# Emails that may open /admin with a normal user JWT (Google SSO or email/password).
# Comma-separated. If unset, defaults to kcramkishore1@gmail.com only.
# Set to empty to disable default list: ADMIN_USER_EMAILS=
# ADMIN_USER_EMAILS=you@company.com,other@company.com

# Optional: operator login POST /api/admin/login (JWT role=admin, 1d expiry)
ADMIN_EMAIL=you@yourcompany.com
ADMIN_PASSWORD=use-a-long-random-secret-here

# ── Google Maps / Places API (New) ───────────────────────────────────────────
# This app uses the NEW Places API (places.googleapis.com/v1), not the legacy one.
# 1. Go to https://console.cloud.google.com/apis/library
# 2. Search for and enable "Places API (New)"
# 3. Go to Credentials → Create Credentials → API Key
# 4. In production: restrict the key to your backend server IP (Application restrictions)
#    and restrict it to "Places API (New)" (API restrictions)
# 5. Paste it here — this key lives ONLY on the server, never in the browser
GOOGLE_MAPS_API_KEY=your-server-api-key-here

# ── Claude (Anthropic) ───────────────────────────────────────────────────────
# Used to auto-generate descriptions, taglines, and website copy from Maps data.
# Get your API key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Vercel ───────────────────────────────────────────────────────────────────
# Personal Access Token for deploying generated sites to Vercel
# Get it at https://vercel.com/account/tokens  → Create Token
VERCEL_TOKEN=your-vercel-token-here

# Custom domain base — generated sites become {slug}.placetopage.com
# Set this to your domain. Requires:
#   1. Domain added to your Vercel account (vercel.com/account/domains)
#   2. Wildcard DNS at your registrar: CNAME  *  cname.vercel-dns.com
CUSTOM_DOMAIN_BASE=placetopage.com

# ── Frontend URL (PayPal return/cancel pages) ────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── PayPal (Go Live $5 — same pattern as Pammi backend) ───────────────────────
# REST app credentials: https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
# sandbox = Sandbox app credentials from developer.paypal.com; production = Live app
PAYPAL_MODE=sandbox
# One-time payment amount in USD (default 5.00)
PAYPAL_GO_LIVE_AMOUNT_USD=5
# How many "publish" credits each purchase grants (default 1)
PAYPAL_GO_LIVE_PUBLISHING_CREDITS=1

# Set to true only for local dev to publish without PayPal (never in production)
SKIP_PUBLISH_PAYMENT=false

# ── Razorpay (India payments) ─────────────────────────────────────────────────
# REST API credentials: https://dashboard.razorpay.com/app/keys
# Use Test keys for sandbox, Live keys for production
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Conversion rate used to charge in INR (default: 84 INR per USD)
# RAZORPAY_USD_TO_INR=84

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated browser origins allowed to call the API (no trailing slash)
# In production add your Vercel frontend URL:
CORS_ORIGINS=http://localhost:5173,https://placetopage-frontend.vercel.app

# ── Google Cloud Storage (optional — “Upload your photo” for hero images) ─────
# 1) Create a bucket: https://console.cloud.google.com/storage → Create bucket
# 2) Create a service account: IAM & Admin → Service Accounts → Create
#    Grant roles: “Storage Object Admin” (or Object Creator + ability to set object public read)
# 3) Keys → Add key → JSON — download the file (local dev) OR copy JSON for Vercel
# 4) Dashboard thumbnails: the app can load private objects via GET /api/upload/file (signed-in users only).
# 5) Published / generated HTML sites load hero images by URL in the browser — those URLs must be
#    publicly readable unless you only use Google Maps photo URLs. For uploaded heroes, either:
#    • Bucket → Permissions → Principal: allUsers → Role: Storage Object Viewer, or
#    • Serve via a public CDN (set GCS_PUBLIC_BASE_URL to match).
#
# Required when uploads are enabled:
GCS_BUCKET_NAME=your-bucket-name
#
# Optional — if you serve objects under a custom host or load balancer (must match object paths):
# GCS_PUBLIC_BASE_URL=https://storage.googleapis.com/your-bucket-name
#
# Pick ONE authentication method:
#
# A) Local / VM: path to the service account JSON file (absolute path recommended)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json
#
# B) Vercel / Docker / CI: paste the full JSON as a single env var (escape newlines or use one line)
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project",...}
#
# Verify credentials + bucket (from backend/: npm run test:gcs)
#
# If neither A nor B is set, the Google client uses Application Default Credentials (e.g. GCE metadata).
